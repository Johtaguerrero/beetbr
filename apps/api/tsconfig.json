{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "paths": {
            "@beetbr/shared": [
                "../../packages/shared/src/index.ts"
            ]
        }
    },
    "include": [
        "src",
        "prisma"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}