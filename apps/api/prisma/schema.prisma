// This is the BEETBR Prisma schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ARTIST
  INDUSTRY
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  DELETED
}

enum ContactVisibility {
  PUBLIC
  VERIFIED_ONLY
  PROPOSAL_ONLY
  PRIVATE
}

enum IndustryType {
  LABEL
  AGENCY
  BRAND
  PRODUCER
  EVENT
  OTHER
}

enum PostType {
  TRACK
  VIDEO
  LYRIC
  AUDIO
  IMAGE
  MARKETPLACE
  COLLAB
}

enum ProposalType {
  LIVE_SHOW
  RECORDING
  FEAT
  MUSIC_VIDEO
  EVENT
  OTHER
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  NEGOTIATING
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
}

enum ContractStatus {
  DRAFT
  UNDER_REVIEW
  SIGNED
  TERMINATED
}

// ============================================================
// CHAT SYSTEM (UNIFIED)
// ============================================================

enum ChatThreadType {
  PROPOSAL
  COLLAB
  MARKETPLACE
  DIRECT
}

model ChatThread {
  id          String         @id @default(uuid())
  type        ChatThreadType
  status      String         @default("ACTIVE")
  
  // Context IDs (Optional depending on type)
  proposalId  String?        @unique
  proposal    Proposal?      @relation("ProposalChat", fields: [proposalId], references: [id])
  
  collabId    String?        @unique
  collab      CollabPost?    @relation("CollabChat", fields: [collabId], references: [id])
  
  listingId   String?        @unique
  listing     Listing?       @relation("ListingChat", fields: [listingId], references: [id])
  
  lastMessage String?        @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  participants User[]        @relation("ChatParticipants")
  messages     ChatMessage[]

  @@map("chat_threads")
}

model ChatMessage {
  id            String      @id @default(uuid())
  threadId      String
  thread        ChatThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId      String
  sender        User        @relation(fields: [senderId], references: [id])
  content       String      @db.Text
  attachmentUrl String?
  attachmentName String?
  isSystem      Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@index([threadId])
  @@index([senderId])
  @@map("chat_messages")
}

// ============================================================
// USER
// ============================================================

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  passwordHash     String?
  googleId         String?    @unique
  role             UserRole
  verified         Boolean    @default(false)
  emailVerifiedAt  DateTime?
  status           UserStatus @default(ACTIVE)
  refreshToken     String?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  artistProfile   ArtistProfile?
  industryProfile IndustryProfile?
  auditLogs       AuditLog[]
  notifications   Notification[]
  followers       Follow[]         @relation("UserFollowers")
  following       Follow[]         @relation("UserFollows")
  
  // Chat relationships
  participatingChats ChatThread[]   @relation("ChatParticipants")
  chatMessages       ChatMessage[]

  @@map("users")
}

// ============================================================
// ARTIST PROFILE
// ============================================================

model ArtistProfile {
  id                 String            @id @default(uuid())
  userId             String            @unique
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  stageName          String
  genres             String[]
  city               String
  state              String            @db.Char(2)
  bio                String            @default("")
  avatarUrl          String?
  coverUrl           String?
  availableForBooking Boolean          @default(true)
  contactVisibility  ContactVisibility @default(PROPOSAL_ONLY)
  scoreBeet          Float             @default(0)
  
  // Identidade e Social
  realName           String?
  pronouns           String?
  birthDate          DateTime?
  bioFull            String?           @db.Text
  
  // Classificacao
  subGenres          String[]
  complementaryStyles String[]
  roles              String[]          // Ex: Cantor, Beatmaker, etc.
  
  // Profissional
  professionalQuestions Json?          // Respostas estruturadas
  status             String?           // Status profissional
  mainGoal           String?           // Objetivo na plataforma
  availabilityStatus String?           // Disponibilidade atual
  opportunityTypes   String[]          // Oportunidades desejadas
  socialProofs       Json?             // Provas sociais (historico)
  
  // Portfolio PDF
  portfolioPdfUrl    String?
  portfolioPdfName   String?

  // Redes Sociais
  instagram          String?
  youtubeUrl         String?
  spotifyUrl         String?
  tiktokUrl          String?
  soundcloudUrl      String?
  deezerUrl          String?
  website            String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  posts        Post[]
  stories      Story[]
  metrics      Metrics?
  proposals    Proposal[]    @relation("ArtistProposals")
  savedBy      SavedArtist[]
  listings     Listing[]
  collabs      CollabPost[]
  targetCollabs CollabPost[] @relation("TargetArtistCollabs")
  interests    CollabInterest[]

  @@map("artist_profiles")
}

// ============================================================
// INDUSTRY PROFILE
// ============================================================

model IndustryProfile {
  id          String       @id @default(uuid())
  userId      String       @unique
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  type        IndustryType
  niches      String[]
  city        String
  state       String       @db.Char(2)
  logoUrl     String?
  coverUrl    String?
  website     String?
  instagram   String?
  verified    Boolean      @default(false)
  cnpj        String?      @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  proposals   Proposal[]    @relation("IndustryProposals")
  shortlists  SavedArtist[]
  listings    Listing[]

  @@map("industry_profiles")
}

// ============================================================
// POST & STORY
// ============================================================

model Post {
  id        String   @id @default(uuid())
  artistId  String
  artist    ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  type      PostType
  text      String?
  mediaUrl  String?
  thumbUrl  String?
  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id])
  collabId  String?
  collab    CollabPost? @relation(fields: [collabId], references: [id])
  duration  Int?     // seconds
  hashtags  String[]
  plays     Int      @default(0)
  likes     Int      @default(0)
  comments  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("posts")
}

model Story {
  id        String   @id @default(uuid())
  artistId  String
  artist    ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  mediaUrl  String
  mediaType String   @default("IMAGE")
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("stories")
}

// ============================================================
// METRICS (BeetAI source data)
// ============================================================

model Metrics {
  id            String   @id @default(uuid())
  artistId      String   @unique
  artist        ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  plays         Int      @default(0)
  views         Int      @default(0)
  engagement    Float    @default(0) // %
  weeklyGrowth  Float    @default(0) // %
  retention     Float    @default(0) // %
  consistency   Float    @default(0) // 0–100
  updatedAt     DateTime @updatedAt

  @@map("metrics")
}

// ============================================================
// PROPOSALS & DEAL ROOM
// ============================================================

model Proposal {
  id               String         @id @default(uuid())
  industryId       String
  industry         IndustryProfile @relation("IndustryProposals", fields: [industryId], references: [id])
  artistId         String
  artist           ArtistProfile   @relation("ArtistProposals", fields: [artistId], references: [id])
  type             ProposalType
  amount           Decimal        @db.Decimal(12, 2)
  date             DateTime?
  location         String?
  online           Boolean        @default(false)
  terms            String?        @db.Text
  durationHours    Int?
  responseDeadline DateTime?
  status           ProposalStatus @default(SENT)
  contractFileUrl  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  contract  Contract?
  chat      ChatThread? @relation("ProposalChat")

  @@map("proposals")
}

// ============================================================
// CONTRACT
// ============================================================

model Contract {
  id         String         @id @default(uuid())
  proposalId String         @unique
  proposal   Proposal       @relation(fields: [proposalId], references: [id])
  status     ContractStatus @default(DRAFT)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  versions ContractFileVersion[]

  @@map("contracts")
}

model ContractFileVersion {
  id           String   @id @default(uuid())
  contractId   String
  contract     Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  version      Int
  fileUrl      String
  fileName     String
  uploadedBy   String   // user ID
  uploaderRole String   // 'ARTIST' | 'INDUSTRY'
  createdAt    DateTime @default(now())

  @@unique([contractId, version])
  @@map("contract_file_versions")
}

// ============================================================
// SHORTLIST
// ============================================================

model SavedArtist {
  industryId String
  industry   IndustryProfile @relation(fields: [industryId], references: [id], onDelete: Cascade)
  artistId   String
  artist     ArtistProfile   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@id([industryId, artistId])
  @@map("saved_artists")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id           String   @id @default(uuid())
  actorUserId  String
  actor        User     @relation(fields: [actorUserId], references: [id])
  action       String
  resourceType String
  resourceId   String
  ip           String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([actorUserId])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

// ============================================================
// MARKETPLACE (Anúncios)
// ============================================================

enum ListingStatus {
  ACTIVE
  PAUSED
  SOLD
  EXPIRED
  DELETED
  CLOSED
}

enum MarketplaceCategory {
  beats
  mixagem
  composicao
  videoclipe
  design
  assessoria
  outros
}

enum ItemCondition {
  NEW
  USED_LIKE_NEW
  USED_GOOD
  USED_FAIR
}

enum PriceType {
  FIXED
  NEGOTIABLE
  CONSULT
}

enum ListingVisibility {
  PUBLIC
  ARTISTS_ONLY
  INDUSTRY_ONLY
}

model Listing {
  id          String              @id @default(uuid())
  sellerId    String
  sellerType  UserRole           // 'ARTIST' or 'INDUSTRY'
  artistSellerId  String?
  industrySellerId String?
  title       String
  description String              @db.Text
  price       Decimal             @db.Decimal(12, 2)
  priceType   PriceType           @default(FIXED)
  category    MarketplaceCategory
  condition   ItemCondition
  location    String
  images      String[]
  audioUrl    String?
  videoUrl    String?
  thumbUrl    String?
  status      ListingStatus       @default(ACTIVE)
  visibility  ListingVisibility   @default(PUBLIC)
  deliveryDays Int?
  revisions    Int?
  licenseType  String?
  views       Int                 @default(0)
  chats       Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  artistSeller   ArtistProfile?   @relation(fields: [artistSellerId], references: [id])
  industrySeller IndustryProfile? @relation(fields: [industrySellerId], references: [id])
  posts          Post[]
  chatThread     ChatThread?      @relation("ListingChat")

  @@index([category])
  @@index([sellerId])
  @@map("listings")
}

// ============================================================
// COLLABORATIONS
// ============================================================

enum CollabStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum CollabRole {
  BEATMAKER
  PRODUCER
  MC
  SINGER
  SONGWRITER
  DJ
  INSTRUMENTALIST
  VIDEO_EDITOR
  VIDEOMAKER
  DESIGNER
  FEAT
  MIX_MASTER
  OTHER
}

enum CollabMode {
  ONLINE
  PRESENCIAL
  HIBRIDO
}

enum CompensationType {
  PAID
  REV_SHARE
  FREE
  NEGOTIABLE
}

model CollabPost {
  id           String           @id @default(uuid())
  authorId     String
  author       ArtistProfile    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title        String
  description  String           @db.Text
  type         CollabRole
  genres       String[]
  subgenres    String[]
  location     String?
  city         String?
  state        String?
  remote       Boolean          @default(false)
  mode         CollabMode       @default(ONLINE)
  compensation CompensationType
  compensationValue Decimal?     @db.Decimal(12, 2)
  status       CollabStatus     @default(ACTIVE)
  views        Int              @default(0)
  interestCount Int             @default(0)
  targetArtistId String?
  targetArtist   ArtistProfile? @relation("TargetArtistCollabs", fields: [targetArtistId], references: [id])
  
  deadline     String?          // Ex: Urgente, 7 dias...
  coverUrl     String?
  audioUrl     String?
  videoUrl     String?
  links        String[]         // Referências externas
  
  publishedInFeed  Boolean      @default(true)
  publishedInStory Boolean      @default(false)
  
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  interests    CollabInterest[]
  posts        Post[]
  chatThread   ChatThread?      @relation("CollabChat")

  @@index([authorId])
  @@index([targetArtistId])
  @@map("collab_posts")
}

model CollabInterest {
  id        String   @id @default(uuid())
  collabId  String
  collab    CollabPost @relation(fields: [collabId], references: [id], onDelete: Cascade)
  userId    String
  message   String   @db.Text
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())

  artist    ArtistProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([collabId])
  @@map("collab_interests")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

enum NotificationType {
  NEW_PROPOSAL
  PROPOSAL_RESPONSE
  NEW_MESSAGE
  COLLAB_INTEREST
  MARKETPLACE_INTERACT
  NEW_FOLLOWER
  NEW_LIKE
  SYSTEM
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String           @db.Text
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@map("notifications")
}

// ============================================================
// CONNECTIONS (FOLLOWS)
// ============================================================

model Follow {
  followerId  String
  follower    User     @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}
